{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "license": "MIT",
  "engines": {
    "node": ">=20 <24"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "pnpm": {
    "overrides": {
      "cookie": "^1.1.1",
      "fast-xml-parser": "^5.8.0",
      "file-type": "^21.3.3",
      "jws": "^4.0.1",
      "lodash": "^4.18.1",
      "@messageformat/runtime": "^3.0.2",
      "@nestjs/mapped-types": "^2.1.1",
      "multer": "^2.1.1",
