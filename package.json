{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  },
  "pnpm": {
    "overrides": {
      "cookie": "^1.1.1",
      "fast-xml-parser": "^5.8.0",
      "file-type": "^21.3.3",
      "jws": "^4.0.1",
      "lodash": "^4.18.1",
      "@messageformat/runtime": "^3.0.2",
      "@nestjs/mapped-types": "^2.1.1",
      "multer": "^2.1.1",
      "picomatch": "^2.3.2",
      "qs": "^6.15.2",
      "js-yaml": "^4.2.0",
      "uuid": "^11.1.1",
      "validator": "^13.15.35"
    }
  },
  "scripts": {
    "setup": "cp packagedev.json package.json",
    "init": "node generate-packages.js && cp packageturbodev.json package.json",
    "build": "npx prisma generate && nest build",
    "dev": "npx prisma generate && pnpm run start:dev",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npx prisma generate && nest start",
    "start:dev": "npx prisma generate && nest start --watch",
    "start:debug": "npx prisma generate && nest start --debug --watch",
    "start:prod": "npx prisma generate && npx prisma migrate deploy && node dist/src/main",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "lint:check": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@alicloud/dypnsapi20170525": "^2.0.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/tea-typescript": "^1.8.0",
    "@alicloud/tea-util": "^1.4.11",
    "@ganxing/utils": "^0.0.4",
    "@ganxing/wechat": "^0.0.2",
    "@golevelup/nestjs-rabbitmq": "^9.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@prisma/client": "^6.19.3",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "amqplib": "^2.0.1",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "exiftool-vendored": "^36.0.0",
    "fs-extra": "^11.3.5",
    "i18n": "^0.15.3",
    "ioredis": "^5.11.1",
    "jwt-decode": "^4.0.0",
    "minio": "^8.0.7",
    "nestjs-i18n": "^10.8.4",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "svg-captcha": "^1.4.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/bcrypt": "^6.0.0",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.9",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.13.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "src/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1"
    },
    "testEnvironment": "node"
  }
}
