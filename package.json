      "qs": "^6.15.2",
      "js-yaml": "^4.2.0",
      "uuid": "^11.1.1",
      "validator": "^13.15.35"
    }
  },
  "scripts": {
    "setup": "cp packagedev.json package.json",
    "init": "node generate-packages.js && cp packageturbodev.json package.json",
    "build": "npx prisma generate && nest build",
    "dev": "npx prisma generate && pnpm run start:dev",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npx prisma generate && nest start",
    "start:dev": "npx prisma generate && nest start --watch",
    "start:debug": "npx prisma generate && nest start --debug --watch",
    "start:prod": "npx prisma generate && npx prisma migrate deploy && node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@alicloud/dypnsapi20170525": "^1.1.0",
